# Copy this file to .env for local development.
# For production, .env.production is used automatically by Vite build.

# LOCAL DEVELOPMENT:
# Leave VITE_API_URL unset — Vite proxy in vite.config.js forwards /api/* to localhost:5000.
# VITE_API_URL=

# FINGERPRINT BRIDGE (optional — only needed if your fingerprint bridge runs on a non-default port)
# VITE_FINGERPRINT_BRIDGE_URL=http://localhost:3001
